# === Bot Mode ===
BOT_MODE=polling                     # polling | webhook

# Custom Database Path
DB_PATH=data/openminicrew.db


# === Webhook (webhook mode only) ===
WEBHOOK_HOST=https://your-domain.com
WEBHOOK_PORT=8443
WEBHOOK_PATH=/bot/webhook
TELEGRAM_WEBHOOK_SECRET=change-this-to-random-string

# === Owner ===
OWNER_TELEGRAM_CHAT_ID=YOUR_CHAT_ID         # get from @userinfobot
OWNER_DISPLAY_NAME=Owner

# === LLM ===
DEFAULT_LLM=gemini                          # claude | gemini

ANTHROPIC_API_KEY=                          # https://console.anthropic.com
GEMINI_API_KEY=                             # https://aistudio.google.com

CLAUDE_MODEL_CHEAP=claude-haiku-4-5-20251001
CLAUDE_MODEL_MID=claude-sonnet-4-5-20250929

GEMINI_MODEL_CHEAP=gemini-2.5-flash
GEMINI_MODEL_MID=gemini-2.5-pro

# === Telegram ===
TELEGRAM_BOT_TOKEN=YOUR_BOT_TOKEN           # from @BotFather

# === Gmail ===
GMAIL_MAX_RESULTS=30

# === External APIs ===
# Google Maps (requires billing account, but has $200/month free tier)
GOOGLE_MAPS_API_KEY=                        # https://console.cloud.google.com/google/maps-apis

# Foursquare (100% free, 100k requests/day)
FOURSQUARE_API_KEY=                         # https://foursquare.com/developers/signup

# === Memory ===
MAX_CONTEXT_MESSAGES=10
CHAT_HISTORY_RETENTION_DAYS=30

# === Location ===
LOCATION_TTL_MINUTES=60                        # TTL ตำแหน่ง GPS (นาที), 0 = ไม่หมดอายุ

# === Schedule ===
TIMEZONE=Asia/Bangkok
MORNING_BRIEFING_TIME=07:00                     # เวลา seed default schedule (HH:MM)
MORNING_BRIEFING_TOOL=email_summary              # tool ที่ seed: email_summary, news_summary, exchange_rate, ...

# === Timeouts (seconds) ===
# DISPATCH_TIMEOUT=120                            # timeout สำหรับ LLM dispatch
# TOOL_EXEC_TIMEOUT=120                           # timeout สำหรับ scheduled tool execution

# === Scheduler tuning ===
# MISSED_JOB_WINDOW_HOURS=12                      # ตรวจ missed jobs ย้อนหลังกี่ชั่วโมง
# HEARTBEAT_INTERVAL_MINUTES=30                   # ความถี่ heartbeat log

# === Cleanup retention (days) ===
# TOOL_LOG_RETENTION_DAYS=90
# EMAIL_LOG_RETENTION_DAYS=90
# PENDING_MSG_RETENTION_DAYS=7
# JOB_RUN_RETENTION_DAYS=30

# === Polling ===
# POLLING_TIMEOUT=30                              # Telegram long-poll timeout
# POLLING_REQUEST_TIMEOUT=35                      # HTTP request timeout (ต้อง > POLLING_TIMEOUT)

# === Work Email (IMAP) ===
WORK_IMAP_HOST=mail.ntplc.co.th
WORK_IMAP_PORT=993
WORK_IMAP_USER=pornthep@ntplc.co.th
WORK_IMAP_PASSWORD=your-password-here
WORK_EMAIL_MAX_RESULTS=30
WORK_EMAIL_ATTACHMENT_MAX_MB=5

# Bank of Thailand API (https://apiportal.bot.or.th)
BOT_API_EXCHANGE_TOKEN=              # สำหรับ Exchange Rate API (ใช้แบบ Bearer)
BOT_API_HOLIDAY_TOKEN=               # สำหรับ Holiday API (ใช้แบบ raw token)